@{
    ViewData["Title"] = "Customers";
}

<div class="sm:flex sm:items-center sm:justify-between mb-8">
    <div>
        <h1 class="text-2xl font-bold text-slate-900 dark:text-slate-100 sm:text-3xl tracking-tight">Customers</h1>
        <p class="mt-2 text-sm text-slate-500">Track customer relationships, spending habits, and outstanding balances.</p>
    </div>
    <div class="mt-4 sm:mt-0 sm:ml-16 sm:flex-none">
        <button onclick="showModal()" class="btn-primary gap-2">
            <i data-lucide="user-plus" class="w-4 h-4"></i>
            Add Customer
        </button>
    </div>
</div>

<div class="card">
    <div class="p-4 border-b border-slate-100 dark:border-slate-800 bg-slate-50 dark:bg-slate-950/50 flex flex-col sm:flex-row gap-4 justify-between items-center">
        <div class="flex items-center gap-3 w-full sm:w-auto">
            <div class="relative w-full sm:max-w-xs">
                <div class="absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none text-slate-400">
                    <i data-lucide="search" class="h-4 w-4"></i>
                </div>
                <input type="text" id="search-input" class="input-field pl-10" placeholder="Search customers...">
            </div>
            <select id="page-size-select" class="input-field w-24 h-10" onchange="changePageSize(this.value)">
                <option value="10">10</option>
                <option value="25">25</option>
                <option value="50">50</option>
            </select>
        </div>
        <button onclick="loadCustomers(1)" class="btn-secondary text-xs h-9 w-full sm:w-auto">
            <i data-lucide="refresh-cw" class="w-4 h-4 mr-2"></i>
            Refresh
        </button>
    </div>

    <div class="overflow-x-auto">
        <table class="min-w-full divide-y divide-slate-200">
            <thead class="bg-slate-50 dark:bg-slate-950">
                <tr>
                    <th class="px-6 py-3.5 text-left text-[11px] font-bold text-slate-500 uppercase tracking-wider">Customer</th>
                    <th class="px-6 py-3.5 text-left text-[11px] font-bold text-slate-500 uppercase tracking-wider">Contact</th>
                    <th class="px-6 py-3.5 text-left text-[11px] font-bold text-slate-500 uppercase tracking-wider">Total Spent</th>
                    <th class="px-6 py-3.5 text-left text-[11px] font-bold text-slate-500 uppercase tracking-wider">Balance</th>
                    <th class="px-6 py-3.5 text-left text-[11px] font-bold text-slate-500 uppercase tracking-wider">Last Order</th>
                    <th class="relative px-6 py-3.5"><span class="sr-only">Actions</span></th>
                </tr>
            </thead>
            <tbody id="customers-body" class="bg-white dark:bg-zinc-900 divide-y divide-slate-100 dark:divide-slate-800">
                <tr>
                    <td colspan="6" class="px-6 py-12 text-center">
                        <div class="flex flex-col items-center justify-center">
                            <i data-lucide="loader-2" class="h-8 w-8 text-indigo-500 animate-spin mb-4"></i>
                            <p class="text-sm text-slate-500 font-medium">Loading customers...</p>
                        </div>
                    </td>
                </tr>
            </tbody>
        </table>
    </div>

    <div id="customers-pagination"></div>
</div>

<!-- Add/Edit Modal -->
<div id="customer-modal" class="fixed inset-0 z-[60] hidden overflow-y-auto" role="dialog" aria-modal="true">
    <div class="flex items-end justify-center min-h-screen pt-4 px-4 pb-20 text-center sm:block sm:p-0">
        <div class="fixed inset-0 bg-slate-900/60" onclick="hideModal()"></div>
        <span class="hidden sm:inline-block sm:align-middle sm:h-screen">&#8203;</span>
        <div class="relative z-10 inline-block align-bottom bg-white dark:bg-zinc-900 rounded-2xl text-left overflow-hidden shadow-2xl sm:my-8 sm:align-middle sm:max-w-lg sm:w-full">
            <div class="bg-white dark:bg-zinc-900 px-4 pt-5 pb-4 sm:p-8 sm:pb-4">
                <div class="sm:flex sm:items-start">
                    <div class="mx-auto flex-shrink-0 flex items-center justify-center h-12 w-12 rounded-xl bg-indigo-50 text-indigo-600 sm:mx-0 sm:h-10 sm:w-10">
                        <i data-lucide="user" class="h-6 w-6"></i>
                    </div>
                    <div class="mt-3 text-center sm:mt-0 sm:ml-4 sm:text-left w-full">
                        <h3 class="text-xl leading-6 font-bold text-slate-900 dark:text-slate-100" id="modal-title">New Customer</h3>
                        <div class="mt-6 space-y-4">
                            <input type="hidden" id="c-id">
                            <div>
                                <label class="block text-sm font-semibold text-slate-700 mb-1">Full Name</label>
                                <input type="text" id="c-name" class="input-field" placeholder="John Doe">
                            </div>
                            <div class="grid grid-cols-2 gap-4">
                                <div>
                                    <label class="block text-sm font-semibold text-slate-700 mb-1">Phone Number</label>
                                    <input type="text" id="c-phone" class="input-field" placeholder="+1 234 567 890">
                                </div>
                                <div>
                                    <label class="block text-sm font-semibold text-slate-700 mb-1">Items Ordered</label>
                                    <input type="number" id="c-items" class="input-field bg-slate-50 dark:bg-slate-950 cursor-not-allowed" disabled placeholder="0">
                                </div>
                            </div>
                            <div>
                                <label class="block text-sm font-semibold text-slate-700 mb-1">Address</label>
                                <textarea id="c-address" rows="3" class="input-field" placeholder="Primary delivery address..."></textarea>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
            <div class="bg-slate-50 dark:bg-slate-950 px-4 py-4 sm:px-8 sm:flex sm:flex-row-reverse gap-3">
                <button type="button" onclick="saveCustomer()" id="save-btn" class="btn-primary w-full sm:w-auto px-8">Save Customer</button>
                <button type="button" onclick="hideModal()" class="btn-secondary w-full sm:w-auto">Cancel</button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        document.getElementById('breadcrumb-parent').textContent = 'CRM';
        document.getElementById('breadcrumb-current').textContent = 'Customers';

        let currentPage = 1;
        let currentPageSize = 10;

        // Formatter for MMK (No decimals, comma separated)
        const mmkFormat = new Intl.NumberFormat('en-US', {
            minimumFractionDigits: 0,
            maximumFractionDigits: 0
        });

        async function loadCustomers(page = 1) {
            currentPage = page;
            const tbody = document.getElementById('customers-body');
            tbody.innerHTML = `<tr><td colspan="6" class="px-6 py-12 text-center">
                <div class="flex flex-col items-center justify-center">
                    <i data-lucide="loader-2" class="h-8 w-8 text-indigo-500 animate-spin mb-4"></i>
                    <p class="text-sm text-slate-500 font-medium">Loading...</p>
                </div></td></tr>`;
            lucide.createIcons();

            const result = await window.api.get(`/customers?pageNumber=${page}&pageSize=${currentPageSize}`);

            if (result && result.isSuccess) {
                const items = result.data || [];
                const paginationMeta = result.pagination || result.Pagination;

                if (items.length === 0) {
                    tbody.innerHTML = `<tr><td colspan="6" class="px-6 py-12 text-center text-slate-400 font-medium">No customers found.</td></tr>`;
                    document.getElementById('customers-pagination').innerHTML = '';
                    return;
                }

                window._customerMap = {};
                items.forEach(item => { window._customerMap[item.id] = item; });

                tbody.innerHTML = items.map(item => {
                    const hasBalance = item.outstandingBalance && item.outstandingBalance > 0;
                    return `
                    <tr class="hover:bg-slate-50 dark:bg-slate-950/80 transition-colors">
                        <td class="px-6 py-4 whitespace-nowrap">
                            <div class="flex items-center">
                                <div class="h-9 w-9 rounded-full bg-indigo-100 border border-indigo-200 flex items-center justify-center mr-3 text-indigo-700 font-black text-xs uppercase flex-shrink-0">
                                    ${item.name.substring(0, 2)}
                                </div>
                                <div>
                                    <div class="text-sm font-bold text-slate-900 dark:text-slate-100">${item.name}</div>
                                    <div class="text-xs text-slate-400 font-medium">${item.address || 'No address'}</div>
                                </div>
                            </div>
                        </td>
                        <td class="px-6 py-4 whitespace-nowrap">
                            ${item.phone
                                ? `<span class="text-sm font-medium text-slate-700">${item.phone}</span>`
                                : `<span class="text-slate-300 italic text-sm">Not set</span>`}
                        </td>
                        <td class="px-6 py-4 whitespace-nowrap">
                            ${item.totalPurchased
                                ? `<span class="text-sm font-black text-emerald-600 tabular-nums">${mmkFormat.format(item.totalPurchased)} MMK</span>`
                                : `<span class="text-slate-300 italic text-sm">No purchases</span>`}
                        </td>
                        <td class="px-6 py-4 whitespace-nowrap">
                            ${hasBalance
                                ? `<span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-bold bg-rose-50 text-rose-600 border border-rose-100">
                                       ${mmkFormat.format(item.outstandingBalance)} MMK due
                                   </span>`
                                : `<span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-bold bg-emerald-50 text-emerald-600 border border-emerald-100">
                                       Settled
                                   </span>`}
                        </td>
                        <td class="px-6 py-4 whitespace-nowrap text-sm text-slate-500 tabular-nums">
                            ${item.lastTransactionDate
                                ? new Date(item.lastTransactionDate).toLocaleDateString(undefined, { month: 'short', day: 'numeric', year: 'numeric' })
                                : '<span class="text-slate-300 italic">Never</span>'}
                        </td>
                        <td class="px-6 py-4 whitespace-nowrap text-right text-sm font-medium">
                            <div class="flex justify-end gap-2">
                                <button onclick="editCustomer(${item.id})"
                                    class="p-1.5 text-slate-400 hover:text-indigo-600 hover:bg-indigo-50 rounded-lg transition-all">
                                    <i data-lucide="edit-3" class="w-4 h-4"></i>
                                </button>
                                <button onclick="deleteCustomer(${item.id})"
                                    class="p-1.5 text-slate-400 hover:text-rose-600 hover:bg-rose-50 rounded-lg transition-all">
                                    <i data-lucide="trash-2" class="w-4 h-4"></i>
                                </button>
                            </div>
                        </td>
                    </tr>`;
                }).join('');
                lucide.createIcons();

                if (paginationMeta) {
                    window.pagination.render('customers-pagination', paginationMeta, loadCustomers);
                }
            } else {
                tbody.innerHTML = `<tr><td colspan="6" class="px-6 py-12 text-center text-rose-500 font-bold">
                    Error: ${result ? result.message : 'Unknown error'}</td></tr>`;
            }
        }

        function changePageSize(size) {
            currentPageSize = parseInt(size);
            loadCustomers(1);
        }

        function showModal() {
            document.getElementById('modal-title').textContent = 'New Customer';
            ['c-id','c-name','c-phone','c-address'].forEach(id => document.getElementById(id).value = '');
            document.getElementById('c-items').value = 0;
            document.getElementById('customer-modal').classList.remove('hidden');
        }

        function hideModal() {
            document.getElementById('customer-modal').classList.add('hidden');
        }

        function editCustomer(id) {
            const item = window._customerMap && window._customerMap[id];
            if (!item) return;
            document.getElementById('modal-title').textContent = 'Edit Customer';
            document.getElementById('c-id').value = item.id;
            document.getElementById('c-name').value = item.name;
            document.getElementById('c-phone').value = item.phone || '';
            document.getElementById('c-address').value = item.address || '';
            document.getElementById('c-items').value = item.totalItems;
            document.getElementById('customer-modal').classList.remove('hidden');
        }

        async function saveCustomer() {
            const id = document.getElementById('c-id').value;
            const name = document.getElementById('c-name').value;
            const phone = document.getElementById('c-phone').value;
            const address = document.getElementById('c-address').value;
            const businessId = parseInt(localStorage.getItem('current_business_id'));

            if (!name) { window.notify.show('Customer name is required', 'error'); return; }

            const saveBtn = document.getElementById('save-btn');
            saveBtn.disabled = true;
            saveBtn.innerHTML = '<i data-lucide="loader-2" class="w-4 h-4 animate-spin mr-2"></i>Saving...';
            lucide.createIcons();

            let versionStamp = null;
            if (id && window._customerMap[id]) {
                versionStamp = window._customerMap[id].versionStamp;
            }

            const result = id
                ? await window.api.put('/customers', { id: parseInt(id), name, phone, address, versionStamp })
                : await window.api.post('/customers', { name, businessId, phone, address });

            if (result && result.isSuccess) {
                window.notify.show(`Customer ${id ? 'updated' : 'added'} successfully`);
                hideModal();
                loadCustomers(currentPage);
            } else {
                window.notify.show(result.message || 'Operation failed', 'error');
            }

            saveBtn.disabled = false;
            saveBtn.textContent = 'Save Customer';
        }

        async function deleteCustomer(id) {
            if (confirm('Permanently remove this customer record?')) {
                const item = window._customerMap && window._customerMap[id];
                const versionStamp = item ? item.versionStamp : null;
                const result = await window.api.delete(`/customers/${id}?version=${encodeURIComponent(versionStamp)}`);
                if (result && result.isSuccess) {
                    window.notify.show('Customer removed');
                    loadCustomers(currentPage);
                } else {
                    window.notify.show(result.message || 'Removal failed', 'error');
                }
            }
        }

        document.getElementById('search-input').addEventListener('input', (e) => {
            const term = e.target.value.toLowerCase();
            document.querySelectorAll('#customers-body tr').forEach(row => {
                row.style.display = row.innerText.toLowerCase().includes(term) ? '' : 'none';
            });
        });

        loadCustomers(1);
    </script>
}
