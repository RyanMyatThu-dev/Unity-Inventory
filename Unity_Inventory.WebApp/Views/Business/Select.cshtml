@{
    Layout = null;
}

<!DOCTYPE html>
<html lang="en" class="h-full bg-slate-50">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Select Business - Unity Inventory</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <script>
        tailwind.config = {
            theme: {
                extend: {
                    fontFamily: {
                        sans: ['Inter', 'sans-serif'],
                    },
                }
            }
        }
    </script>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <script src="https://unpkg.com/lucide@latest"></script>
</head>
<body class="h-full flex items-center justify-center p-4 sm:p-6 lg:p-8">
    <div class="absolute inset-0 z-0 overflow-hidden pointer-events-none">
        <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[60%] h-[60%] bg-indigo-500/5 rounded-full blur-3xl"></div>
    </div>

    <div class="w-full max-w-2xl z-10">
        <div class="text-center mb-10">
            <h1 class="text-3xl font-extrabold text-slate-900 tracking-tight">Select your business</h1>
            <p class="text-slate-500 mt-2">Choose an organization to continue to your dashboard</p>
        </div>

        <div id="business-list" class="grid grid-cols-1 sm:grid-cols-2 gap-4">
            <!-- Loaded via JS -->
            <div class="sm:col-span-2 text-center py-12">
                <i data-lucide="loader-2" class="w-8 h-8 text-indigo-500 animate-spin mx-auto mb-4"></i>
                <p class="text-slate-400 font-medium">Loading your organizations...</p>
            </div>
        </div>

        <div class="mt-8 text-center flex flex-col gap-4">
            <button onclick="showCreateModal()" class="text-indigo-600 font-bold hover:text-indigo-500 transition-colors flex items-center justify-center gap-2">
                <i data-lucide="plus-circle" class="w-5 h-5"></i>
                Create a new business
            </button>
            <button onclick="logout()" class="text-sm font-bold text-slate-400 hover:text-slate-600 transition-colors uppercase tracking-widest">
                Sign out
            </button>
        </div>
    </div>

    <!-- Create Business Modal -->
    <div id="create-modal" class="fixed inset-0 z-50 hidden overflow-y-auto" role="dialog" aria-modal="true">
        <div class="flex items-end justify-center min-h-screen pt-4 px-4 pb-20 text-center sm:block sm:p-0">
            <div class="fixed inset-0 bg-slate-900/60 transition-opacity" onclick="hideCreateModal()"></div>
            <span class="hidden sm:inline-block sm:align-middle sm:h-screen">&#8203;</span>
            <div class="relative z-10 inline-block align-bottom bg-white rounded-3xl text-left overflow-hidden shadow-2xl transform transition-all sm:my-8 sm:align-middle sm:max-w-md sm:w-full">
                <div class="p-8">
                    <div class="flex items-center gap-4 mb-6">
                        <div class="h-12 w-12 rounded-2xl bg-indigo-50 text-indigo-600 flex items-center justify-center">
                            <i data-lucide="building-2" class="w-6 h-6"></i>
                        </div>
                        <h3 class="text-xl font-bold text-slate-900">New Business</h3>
                    </div>
                    <div class="space-y-4">
                        <div>
                            <label class="block text-sm font-semibold text-slate-700 mb-1">Business Name</label>
                            <input type="text" id="b-name" class="w-full px-4 py-3 rounded-xl border border-slate-200 focus:ring-2 focus:ring-indigo-500 outline-none transition-all" placeholder="e.g. Acme Corp">
                        </div>
                        <div>
                            <label class="block text-sm font-semibold text-slate-700 mb-1">Subscription Tier</label>
                            <select id="b-tier" class="w-full px-4 py-3 rounded-xl border border-slate-200 focus:ring-2 focus:ring-indigo-500 outline-none transition-all">
                                <option value="Free">Free Tier</option>
                                <option value="Pro">Pro Tier ($29/mo)</option>
                                <option value="Enterprise">Enterprise</option>
                            </select>
                        </div>
                    </div>
                </div>
                <div class="px-8 py-6 bg-slate-50 flex flex-col sm:flex-row-reverse gap-3">
                    <button onclick="createBusiness()" id="create-btn" class="w-full sm:w-auto px-8 py-3 bg-indigo-600 text-white font-bold rounded-xl shadow-lg shadow-indigo-600/20 hover:bg-indigo-700 transition-all">Create Business</button>
                    <button onclick="hideCreateModal()" class="w-full sm:w-auto px-6 py-3 text-slate-500 font-bold hover:text-slate-700">Cancel</button>
                </div>
            </div>
        </div>
    </div>

    <script src="~/js/api.js"></script>
    <script src="~/js/auth.js"></script>
    <script>
        lucide.createIcons();

        async function loadBusinesses() {
            const list = document.getElementById('business-list');
            const businessesData = localStorage.getItem('user_businesses');
            
            if (businessesData) {
                const items = JSON.parse(businessesData);
                if (items.length === 0) {
                    list.innerHTML = `
                        <div class="sm:col-span-2 bg-white rounded-3xl p-10 border border-slate-200 text-center">
                            <div class="w-16 h-16 bg-slate-50 rounded-2xl flex items-center justify-center mx-auto mb-4">
                                <i data-lucide="building-2" class="w-8 h-8 text-slate-300"></i>
                            </div>
                            <h3 class="text-lg font-bold text-slate-900">No businesses found</h3>
                            <p class="text-slate-500 mt-1 mb-6">You haven't been added to any business yet.</p>
                            <button class="bg-indigo-600 text-white px-6 py-3 rounded-xl font-bold text-sm shadow-lg shadow-indigo-600/20">Create New Business</button>
                        </div>
                    `;
                } else {
                    list.innerHTML = items.map(b => `
                        <button onclick="selectBusiness(${b.businessId || b.BusinessId})" class="group bg-white hover:bg-indigo-600 p-6 rounded-3xl border border-slate-200 hover:border-indigo-600 shadow-sm hover:shadow-xl hover:shadow-indigo-600/20 transition-all text-left flex items-center gap-4">
                            <div class="h-12 w-12 rounded-2xl bg-indigo-50 group-hover:bg-white/20 flex items-center justify-center flex-shrink-0 text-indigo-600 group-hover:text-white transition-colors">
                                <i data-lucide="briefcase" class="w-6 h-6"></i>
                            </div>
                            <div>
                                <h3 class="text-base font-bold text-slate-900 group-hover:text-white transition-colors">${b.businessName || b.BusinessName}</h3>
                                <p class="text-xs font-medium text-slate-400 group-hover:text-indigo-100 transition-colors uppercase tracking-wider">${b.role || b.Role || 'Member'}</p>
                            </div>
                        </button>
                    `).join('');
                }
                lucide.createIcons();
            } else {
                list.innerHTML = `<div class="sm:col-span-2 text-rose-500 font-bold text-center">Session expired. Please log in again.</div>`;
            }
        }

        async function selectBusiness(id) {
            const result = await window.auth.switchBusiness(id);
            if (result.success) {
                window.location.href = '/Dashboard';
            } else {
                alert(result.message);
            }
        }

        function showCreateModal() {
            document.getElementById('b-name').value = '';
            document.getElementById('create-modal').classList.remove('hidden');
        }

        function hideCreateModal() {
            document.getElementById('create-modal').classList.add('hidden');
        }

        async function createBusiness() {
            const name = document.getElementById('b-name').value;
            const tier = document.getElementById('b-tier').value;
            
            if (!name) return alert('Please enter a business name');

            const btn = document.getElementById('create-btn');
            btn.disabled = true;
            btn.innerHTML = '<i data-lucide="loader-2" class="w-4 h-4 animate-spin"></i>';
            lucide.createIcons();

            const result = await window.api.post('/business/create', { businessName: name, subscriptionTier: tier });
            
            if (result && result.isSuccess) {
                // Refresh the business list from the server
                const refreshRes = await window.api.get('/business/my-businesses');
                if (refreshRes && refreshRes.isSuccess) {
                    localStorage.setItem('user_businesses', JSON.stringify(refreshRes.data || []));
                    hideCreateModal();
                    loadBusinesses();
                } else {
                    window.location.reload();
                }
            } else {
                alert(result.message || 'Creation failed');
            }
            
            btn.disabled = false;
            btn.textContent = 'Create Business';
        }

        function logout() {
            window.api.logout();
            window.location.href = '/Account/Login';
        }

        loadBusinesses();
    </script>
</body>
</html>
