@{
    ViewData["Title"] = "Sales Reports";
}

<div class="sm:flex sm:items-center sm:justify-between mb-8">
    <div>
        <h1 class="text-2xl font-bold text-slate-900 sm:text-3xl tracking-tight">Sales Reports</h1>
        <p class="mt-2 text-sm text-slate-500">Track revenue, generate vouchers, and analyze customer transactions.</p>
    </div>
    <div class="mt-4 sm:mt-0 sm:ml-16 sm:flex-none">
        <button onclick="showModal()" class="btn-primary gap-2">
            <i data-lucide="file-plus" class="w-4 h-4"></i>
            New Transaction
        </button>
    </div>
</div>

<div class="card mb-10">
    <div class="p-4 border-b border-slate-100 bg-slate-50/50 flex flex-col sm:flex-row gap-4 justify-between items-center">
        <div class="flex items-center gap-3 w-full sm:w-auto">
            <div class="relative w-full sm:max-w-xs">
                <div class="absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none text-slate-400">
                    <i data-lucide="search" class="h-4 w-4"></i>
                </div>
                <input type="text" id="search-input" class="input-field pl-10" placeholder="Search reports...">
            </div>
            <select id="page-size-select" class="input-field w-24 h-10" onchange="changePageSize(this.value)">
                <option value="10">10</option>
                <option value="25">25</option>
                <option value="50">50</option>
            </select>
        </div>
        <div class="flex gap-2">
            <button onclick="printSalesReportList()" class="btn-secondary text-xs h-9">
                <i data-lucide="printer" class="w-4 h-4 mr-2"></i>
                Print List
            </button>
            <button onclick="loadReports(1)" class="btn-secondary text-xs h-9">
                <i data-lucide="refresh-cw" class="w-4 h-4 mr-2"></i>
                Sync
            </button>
        </div>
    </div>

    <div class="overflow-x-auto">
        <table class="min-w-full divide-y divide-slate-200">
            <thead class="bg-slate-50">
                <tr>
                    <th class="px-6 py-3.5 text-left text-[11px] font-bold text-slate-500 uppercase tracking-wider">Date</th>
                    <th class="px-6 py-3.5 text-left text-[11px] font-bold text-slate-500 uppercase tracking-wider">Customer</th>
                    <th class="px-6 py-3.5 text-left text-[11px] font-bold text-slate-500 uppercase tracking-wider">Total Amount</th>
                    <th class="px-6 py-3.5 text-left text-[11px] font-bold text-slate-500 uppercase tracking-wider">Remarks</th>
                    <th class="relative px-6 py-3.5"><span class="sr-only">Actions</span></th>
                </tr>
            </thead>
            <tbody id="reports-body" class="bg-white divide-y divide-slate-100">
                <tr>
                    <td colspan="5" class="px-6 py-12 text-center">
                        <div class="flex flex-col items-center justify-center">
                            <i data-lucide="loader-2" class="h-8 w-8 text-indigo-500 animate-spin mb-4"></i>
                            <p class="text-sm text-slate-500 font-medium">Fetching reports...</p>
                        </div>
                    </td>
                </tr>
            </tbody>
        </table>
    </div>

    <!-- Pagination -->
    <div id="reports-pagination"></div>
</div>

<!-- New Transaction Modal -->
<div id="report-modal" class="fixed inset-0 z-[60] hidden overflow-y-auto" role="dialog" aria-modal="true">
    <div class="flex items-end justify-center min-h-screen pt-4 px-4 pb-20 text-center sm:block sm:p-0">
        <div class="fixed inset-0 bg-slate-900/60" onclick="hideModal()"></div>
        <span class="hidden sm:inline-block sm:align-middle sm:h-screen">&#8203;</span>
        <div class="relative z-10 inline-block align-bottom bg-white rounded-2xl text-left overflow-hidden shadow-2xl transform transition-all sm:my-8 sm:align-middle sm:max-w-3xl sm:w-full">
            <div class="bg-white px-4 pt-5 pb-4 sm:p-8 sm:pb-4">
                <div class="sm:flex sm:items-start">
                    <div class="mx-auto flex-shrink-0 flex items-center justify-center h-12 w-12 rounded-xl bg-indigo-50 text-indigo-600 sm:mx-0 sm:h-10 sm:w-10">
                        <i data-lucide="receipt" class="h-6 w-6"></i>
                    </div>
                    <div class="mt-3 text-center sm:mt-0 sm:ml-4 sm:text-left w-full">
                        <h3 class="text-xl leading-6 font-bold text-slate-900">New Transaction</h3>
                        <div class="mt-8 grid grid-cols-1 md:grid-cols-2 gap-6">
                            <div>
                                <label class="block text-sm font-semibold text-slate-700 mb-1">Customer</label>
                                <select id="r-customer" class="input-field">
                                    <option value="">Select a customer...</option>
                                </select>
                            </div>
                            <div>
                                <label class="block text-sm font-semibold text-slate-700 mb-1">Date</label>
                                <input type="date" id="r-date" class="input-field">
                            </div>
                            <div class="md:col-span-2">
                                <label class="block text-sm font-semibold text-slate-700 mb-1">Remarks</label>
                                <input type="text" id="r-remarks" class="input-field" placeholder="Optional notes...">
                            </div>
                        </div>
                        <div class="mt-10">
                            <div class="flex justify-between items-center mb-4">
                                <h4 class="text-sm font-bold text-slate-900 uppercase tracking-widest">Line Items</h4>
                                <button onclick="addVoucherRow()" class="text-xs font-bold text-indigo-600 hover:text-indigo-500 flex items-center gap-1">
                                    <i data-lucide="plus" class="w-3 h-3"></i> Add Item
                                </button>
                            </div>
                            <div class="bg-slate-50 rounded-xl border border-slate-200 overflow-hidden">
                                <table class="min-w-full divide-y divide-slate-200">
                                    <thead class="bg-slate-100/50">
                                        <tr>
                                            <th class="px-4 py-2 text-left text-[10px] font-bold text-slate-500 uppercase tracking-wider">Product</th>
                                            <th class="px-4 py-2 text-left text-[10px] font-bold text-slate-500 uppercase tracking-wider w-24">Qty</th>
                                            <th class="px-4 py-2 text-left text-[10px] font-bold text-slate-500 uppercase tracking-wider w-32">Sell Price</th>
                                            <th class="px-4 py-2 text-right text-[10px] font-bold text-slate-500 uppercase tracking-wider w-32">Subtotal</th>
                                            <th class="px-4 py-2 w-10"></th>
                                        </tr>
                                    </thead>
                                    <tbody id="vouchers-body" class="divide-y divide-slate-200 bg-white"></tbody>
                                    <tfoot class="bg-slate-50 font-bold">
                                        <tr>
                                            <td colspan="3" class="px-4 py-3 text-right text-sm text-slate-500">Grand Total</td>
                                            <td class="px-4 py-3 text-right text-base text-slate-900 tabular-nums" id="grand-total">$0.00</td>
                                            <td></td>
                                        </tr>
                                    </tfoot>
                                </table>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
            <div class="bg-slate-50 px-4 py-4 sm:px-8 sm:flex sm:flex-row-reverse gap-3">
                <button type="button" onclick="saveReport()" id="save-btn" class="btn-primary w-full sm:w-auto px-8 shadow-lg shadow-indigo-600/20">Finalize Transaction</button>
                <button type="button" onclick="hideModal()" class="btn-secondary w-full sm:w-auto">Cancel</button>
            </div>
        </div>
    </div>
</div>

<!-- Report Detail Modal -->
<div id="detail-modal" class="fixed inset-0 z-[70] hidden overflow-y-auto" role="dialog" aria-modal="true">
    <div class="flex items-end justify-center min-h-screen pt-4 px-4 pb-20 text-center sm:block sm:p-0">
        <div class="fixed inset-0 bg-slate-900/60" onclick="hideDetailModal()"></div>
        <span class="hidden sm:inline-block sm:align-middle sm:h-screen">&#8203;</span>
        <div class="relative z-10 inline-block align-bottom bg-white rounded-2xl text-left overflow-hidden shadow-2xl transform transition-all sm:my-8 sm:align-middle sm:max-w-2xl sm:w-full">
            <div class="p-8">
                <div class="flex justify-between items-start mb-6">
                    <div>
                        <h3 class="text-xl font-bold text-slate-900" id="detail-title">Transaction Detail</h3>
                        <p class="text-sm text-slate-400 font-medium mt-1" id="detail-meta"></p>
                    </div>
                    <div class="flex gap-2">
                        <button id="detail-print-btn" class="text-slate-400 hover:text-emerald-600 p-2 rounded-lg hover:bg-emerald-50 transition-all" title="Print PDF">
                            <i data-lucide="printer" class="w-5 h-5"></i>
                        </button>
                        <button onclick="hideDetailModal()" class="text-slate-400 hover:text-slate-600 p-2 rounded-lg hover:bg-slate-100 transition-all">
                            <i data-lucide="x" class="w-5 h-5"></i>
                        </button>
                    </div>
                </div>
                <div id="detail-body"></div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        document.getElementById('breadcrumb-parent').textContent = 'Accounting';
        document.getElementById('breadcrumb-current').textContent = 'Sales';

        let currentPage = 1;
        let currentPageSize = 10;
        let products = [];
        let customers = [];

        // Formatter for MMK
        const mmkFormat = new Intl.NumberFormat('en-US', {
            minimumFractionDigits: 0,
            maximumFractionDigits: 0
        });

        async function loadData() {
            const [prodRes, custRes] = await Promise.all([
                window.api.get('/inventories?pageNumber=1&pageSize=1000'),
                window.api.get('/customers?pageNumber=1&pageSize=1000')
            ]);
            products = prodRes.data || [];
            customers = custRes.data || [];

            const custSelect = document.getElementById('r-customer');
            custSelect.innerHTML = '<option value="">Select a customer...</option>' +
                customers.map(c => `<option value="${c.id}">${c.name}</option>`).join('');

            loadReports(1);
        }

        async function loadReports(page = 1) {
            currentPage = page;
            const tbody = document.getElementById('reports-body');
            tbody.innerHTML = `<tr><td colspan="5" class="px-6 py-12 text-center">
                <div class="flex flex-col items-center justify-center">
                    <i data-lucide="loader-2" class="h-8 w-8 text-indigo-500 animate-spin mb-4"></i>
                    <p class="text-sm text-slate-500 font-medium">Loading...</p>
                </div></td></tr>`;
            lucide.createIcons();

            const result = await window.api.get(`/sales/reports?pageNumber=${page}&pageSize=${currentPageSize}`);

            if (result && result.isSuccess) {
                const items = result.data || [];
                const paginationMeta = result.pagination || result.Pagination;

                if (items.length === 0) {
                    tbody.innerHTML = `<tr><td colspan="5" class="px-6 py-12 text-center text-slate-400 font-medium">No sales reports found.</td></tr>`;
                    document.getElementById('reports-pagination').innerHTML = '';
                    return;
                }

                tbody.innerHTML = items.map(item => `
                    <tr class="hover:bg-slate-50/80 transition-colors">
                        <td class="px-6 py-4 whitespace-nowrap text-sm font-bold text-slate-900 tabular-nums">
                            ${new Date(item.reportDate).toLocaleDateString(undefined, { year: 'numeric', month: 'short', day: 'numeric' })}
                        </td>
                        <td class="px-6 py-4 whitespace-nowrap">
                            <div class="flex items-center">
                                <div class="h-8 w-8 rounded bg-slate-100 flex items-center justify-center mr-3 text-slate-400">
                                    <i data-lucide="user" class="w-4 h-4"></i>
                                </div>
                                <span class="text-sm font-semibold text-slate-700">${item.customerName}</span>
                            </div>
                        </td>
                        <td class="px-6 py-4 whitespace-nowrap text-sm font-black text-emerald-600 tabular-nums">
                            ${mmkFormat.format(item.totalAmount)} MMK
                        </td>
                        <td class="px-6 py-4 text-sm text-slate-500 max-w-xs truncate">
                            ${item.remarks || '<span class="text-slate-300 italic">No remarks</span>'}
                        </td>
                        <td class="px-6 py-4 whitespace-nowrap text-right text-sm font-medium">
                            <div class="flex justify-end gap-2">
                                <button onclick="printReport(${item.id})"
                                    class="p-1.5 text-slate-400 hover:text-emerald-600 hover:bg-emerald-50 rounded-lg transition-all" title="Print PDF">
                                    <i data-lucide="printer" class="w-4 h-4"></i>
                                </button>
                                <button onclick="viewReport(${item.id})"
                                    class="p-1.5 text-slate-400 hover:text-indigo-600 hover:bg-indigo-50 rounded-lg transition-all" title="View Details">
                                    <i data-lucide="eye" class="w-4 h-4"></i>
                                </button>
                                <button onclick="deleteReport(${item.id})"
                                    class="p-1.5 text-slate-400 hover:text-rose-600 hover:bg-rose-50 rounded-lg transition-all" title="Delete">
                                    <i data-lucide="trash-2" class="w-4 h-4"></i>
                                </button>
                            </div>
                        </td>
                    </tr>
                `).join('');
                lucide.createIcons();

                if (paginationMeta) {
                    window.pagination.render('reports-pagination', paginationMeta, loadReports);
                }
            } else {
                tbody.innerHTML = `<tr><td colspan="5" class="px-6 py-12 text-center text-rose-500 font-bold">
                    Error: ${result ? result.message : 'Unknown error'}</td></tr>`;
            }
        }

        function changePageSize(size) {
            currentPageSize = parseInt(size);
            loadReports(1);
        }

        function showModal() {
            document.getElementById('r-customer').value = '';
            document.getElementById('r-remarks').value = '';
            document.getElementById('r-date').value = new Date().toISOString().split('T')[0];
            document.getElementById('vouchers-body').innerHTML = '';
            addVoucherRow();
            document.getElementById('report-modal').classList.remove('hidden');
            document.getElementById('r-customer').onchange = () => refreshAllRowPrices();
        }

        function hideModal() {
            document.getElementById('report-modal').classList.add('hidden');
        }

        function hideDetailModal() {
            document.getElementById('detail-modal').classList.add('hidden');
        }

        function addVoucherRow() {
            const tbody = document.getElementById('vouchers-body');
            const row = document.createElement('tr');
            row.className = 'voucher-row group';
            row.innerHTML = `
                <td class="px-2 py-2">
                    <select class="p-prod w-full text-sm font-semibold text-slate-700 border-0 bg-transparent focus:ring-0 focus:outline-none" onchange="updateRowPrice(this)">
                        <option value="">Select product...</option>
                        ${products.map(p => `<option value="${p.id}" data-price="${p.price}">${p.name}</option>`).join('')}
                    </select>
                </td>
                <td class="px-2 py-2">
                    <input type="number" value="1" min="1" class="p-qty w-full text-sm font-bold text-slate-700 border-0 bg-transparent focus:ring-0 focus:outline-none tabular-nums" onchange="calculateTotals()">
                </td>
                <td class="px-2 py-2">
                    <input type="number" class="p-price w-full text-sm font-bold text-slate-700 border-0 bg-transparent focus:ring-0 focus:outline-none tabular-nums" onchange="calculateTotals()" placeholder="0">
                </td>
                <td class="px-4 py-2 text-right text-sm font-black text-slate-900 tabular-nums p-total">0 MMK</td>
                <td class="px-2 py-2 text-center">
                    <button onclick="this.closest('tr').remove(); calculateTotals();"
                        class="text-slate-300 hover:text-rose-500 opacity-0 group-hover:opacity-100 transition-all">
                        <i data-lucide="x-circle" class="w-4 h-4"></i>
                    </button>
                </td>
            `;
            tbody.appendChild(row);
            lucide.createIcons();
        }

        async function updateRowPrice(select) {
            const row = select.closest('tr');
            const inventoryId = parseInt(select.value);
            if (!inventoryId) return;

            const customerId = parseInt(document.getElementById('r-customer').value);
            const priceInput = row.querySelector('.p-price');
            priceInput.value = '';
            priceInput.placeholder = '...';

            if (customerId) {
                const result = await window.api.get(`/customer-prices/effective?customerId=${customerId}&inventoryId=${inventoryId}`);
                if (result && result.isSuccess) {
                    priceInput.value = Math.round(result.data);
                    priceInput.placeholder = '0';
                    const isCustom = result.message && result.message.toLowerCase().includes('custom');
                    priceInput.classList.toggle('text-indigo-600', isCustom);
                } else {
                    const defaultPrice = select.selectedOptions[0]?.dataset?.price;
                    if (defaultPrice) priceInput.value = Math.round(defaultPrice);
                    priceInput.placeholder = '0';
                }
            } else {
                const defaultPrice = select.selectedOptions[0]?.dataset?.price;
                if (defaultPrice) priceInput.value = Math.round(defaultPrice);
                priceInput.placeholder = '0';
            }

            calculateTotals();
        }

        async function refreshAllRowPrices() {
            const rows = document.querySelectorAll('.voucher-row');
            for (const row of rows) {
                const select = row.querySelector('.p-prod');
                if (select && select.value) {
                    await updateRowPrice(select);
                }
            }
        }

        function calculateTotals() {
            let grandTotal = 0;
            document.querySelectorAll('.voucher-row').forEach(row => {
                const qty = parseInt(row.querySelector('.p-qty').value) || 0;
                const price = parseFloat(row.querySelector('.p-price').value) || 0;
                const total = qty * price;
                row.querySelector('.p-total').textContent = `${mmkFormat.format(total)} MMK`;
                grandTotal += total;
            });
            document.getElementById('grand-total').textContent = `${mmkFormat.format(grandTotal)} MMK`;
        }

        async function saveReport() {
            const customerId = parseInt(document.getElementById('r-customer').value);
            const reportDate = document.getElementById('r-date').value;
            const remarks = document.getElementById('r-remarks').value;
            const businessId = parseInt(localStorage.getItem('current_business_id'));

            if (!customerId) { window.notify.show('Please select a customer', 'error'); return; }

            const vouchers = [];
            document.querySelectorAll('.voucher-row').forEach(row => {
                const inventoryId = parseInt(row.querySelector('.p-prod').value);
                const quantity = parseInt(row.querySelector('.p-qty').value);
                const sellPrice = parseFloat(row.querySelector('.p-price').value);
                if (inventoryId && quantity > 0 && sellPrice > 0) {
                    vouchers.push({ inventoryId, quantity, sellPrice });
                }
            });

            if (vouchers.length === 0) { window.notify.show('Please add at least one line item', 'error'); return; }

            const saveBtn = document.getElementById('save-btn');
            saveBtn.disabled = true;
            saveBtn.innerHTML = '<i data-lucide="loader-2" class="w-4 h-4 animate-spin mr-2"></i>Finalizing...';
            lucide.createIcons();

            const result = await window.api.post('/sales/reports', {
                businessId,
                customerId,
                reportDate: new Date(reportDate).toISOString(),
                remarks,
                vouchers
            });

            if (result && result.isSuccess) {
                window.notify.show('Transaction finalized successfully');
                hideModal();
                loadReports(1);
            } else {
                window.notify.show(result.message || 'Transaction failed', 'error');
            }

            saveBtn.disabled = false;
            saveBtn.textContent = 'Finalize Transaction';
        }

        async function viewReport(id) {
            const result = await window.api.get(`/sales/reports/${id}`);
            if (result && result.isSuccess) {
                const report = result.data;
                document.getElementById('detail-title').textContent = `Transaction #${report.id}`;
                document.getElementById('detail-meta').textContent =
                    `${report.customerName} · ${new Date(report.reportDate).toLocaleDateString(undefined, { year: 'numeric', month: 'long', day: 'numeric' })}`;

                document.getElementById('detail-body').innerHTML = `
                    <div class="space-y-4">
                        <div class="bg-slate-50 rounded-xl border border-slate-200 overflow-hidden">
                            <table class="min-w-full divide-y divide-slate-200">
                                <thead class="bg-slate-100/50">
                                    <tr>
                                        <th class="px-4 py-2.5 text-left text-[10px] font-bold text-slate-500 uppercase tracking-wider">Product</th>
                                        <th class="px-4 py-2.5 text-right text-[10px] font-bold text-slate-500 uppercase tracking-wider">Qty</th>
                                        <th class="px-4 py-2.5 text-right text-[10px] font-bold text-slate-500 uppercase tracking-wider">Unit Price</th>
                                        <th class="px-4 py-2.5 text-right text-[10px] font-bold text-slate-500 uppercase tracking-wider">Subtotal</th>
                                    </tr>
                                </thead>
                                <tbody class="divide-y divide-slate-100 bg-white">
                                    ${(report.vouchers || []).map(v => `
                                        <tr>
                                            <td class="px-4 py-3 text-sm font-semibold text-slate-800">${v.inventoryName}</td>
                                            <td class="px-4 py-3 text-sm text-slate-500 text-right tabular-nums">${v.quantity}</td>
                                            <td class="px-4 py-3 text-sm text-slate-500 text-right tabular-nums">${mmkFormat.format(v.sellPrice)} MMK</td>
                                            <td class="px-4 py-3 text-sm font-bold text-slate-800 text-right tabular-nums">${mmkFormat.format(v.subTotal)} MMK</td>
                                        </tr>
                                    `).join('')}
                                </tbody>
                                <tfoot class="bg-slate-50">
                                    <tr>
                                        <td colspan="3" class="px-4 py-3 text-right text-sm font-bold text-slate-600">Total</td>
                                        <td class="px-4 py-3 text-right text-base font-black text-emerald-600 tabular-nums">${mmkFormat.format(report.totalAmount)} MMK</td>
                                    </tr>
                                </tfoot>
                            </table>
                        </div>
                        ${report.remarks ? `<p class="text-sm text-slate-500 italic px-1"><span class="font-bold text-slate-700 not-italic">Remarks:</span> ${report.remarks}</p>` : ''}
                    </div>
                `;
                document.getElementById('detail-modal').classList.remove('hidden');
                document.getElementById('detail-print-btn').onclick = () => printReport(id);
                lucide.createIcons();
            } else {
                window.notify.show('Could not load report details', 'error');
            }
        }

        async function deleteReport(id) {
            if (confirm('Permanently delete this transaction record?')) {
                const result = await window.api.delete(`/sales/reports/${id}`);
                if (result && result.isSuccess) {
                    window.notify.show('Transaction deleted');
                    loadReports(currentPage);
                } else {
                    window.notify.show(result.message || 'Deletion failed', 'error');
                }
            }
        }

        function printReport(id) {
            const token = window.api.getToken();
            window.open(`/Sales/PrintReport/${id}?token=${token}`, '_blank');
        }

        function printSalesReportList() {
            const businessId = localStorage.getItem('current_business_id');
            if (!businessId) {
                window.notify.show('Please select a business first', 'error');
                return;
            }
            const token = window.api.getToken();
            window.open(`/Sales/PrintSalesList?businessId=${businessId}&token=${token}`, '_blank');
        }

        document.getElementById('search-input').addEventListener('input', (e) => {
            const term = e.target.value.toLowerCase();
            document.querySelectorAll('#reports-body tr').forEach(row => {
                row.style.display = row.innerText.toLowerCase().includes(term) ? '' : 'none';
            });
        });

        loadData();
    </script>
}
