@model IMS.WebApp.Models.ReportDTO
@{
    Layout = null;
}

<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <title>Transaction Report #@Model.Id</title>
    <style>
        body {
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            color: #1e293b;
            margin: 0;
            padding: 40px;
            font-size: 14px;
            line-height: 1.5;
        }

        .header {
            display: flex;
            justify-content: space-between;
            align-items: flex-start;
            border-bottom: 2px solid #e2e8f0;
            padding-bottom: 20px;
            margin-bottom: 30px;
        }

        .company-info h1 {
            margin: 0;
            color: #4f46e5;
            font-size: 28px;
            font-weight: 800;
            letter-spacing: -0.025em;
        }

        .company-info p {
            margin: 5px 0 0 0;
            color: #64748b;
            font-weight: 500;
        }

        .report-info {
            text-align: right;
        }

        .report-info h2 {
            margin: 0;
            font-size: 20px;
            color: #0f172a;
        }

        .report-info p {
            margin: 5px 0 0 0;
            color: #64748b;
            font-family: 'Courier New', Courier, monospace;
            font-weight: bold;
        }

        .details-grid {
            display: table;
            width: 100%;
            margin-bottom: 40px;
        }

        .details-col {
            display: table-cell;
            width: 50%;
            vertical-align: top;
        }

        .label {
            font-size: 11px;
            text-transform: uppercase;
            color: #94a3b8;
            font-weight: 700;
            letter-spacing: 0.05em;
            margin-bottom: 4px;
        }

        .value {
            font-size: 16px;
            font-weight: 600;
            color: #1e293b;
        }

        table {
            width: 100%;
            border-collapse: collapse;
            margin-bottom: 30px;
        }

        th {
            background-color: #f8fafc;
            color: #64748b;
            text-align: left;
            padding: 12px 15px;
            font-size: 11px;
            text-transform: uppercase;
            font-weight: 700;
            letter-spacing: 0.05em;
            border-bottom: 2px solid #e2e8f0;
        }

        td {
            padding: 12px 15px;
            border-bottom: 1px solid #f1f5f9;
        }

        .text-right {
            text-align: right;
        }

        .font-mono {
            font-family: 'Courier New', Courier, monospace;
        }

        .totals {
            float: right;
            width: 300px;
        }

        .total-row {
            display: flex;
            justify-content: space-between;
            padding: 10px 0;
        }

        .grand-total {
            border-top: 2px solid #e2e8f0;
            margin-top: 10px;
            padding-top: 15px;
            font-size: 20px;
            font-weight: 800;
            color: #059669;
        }

        .remarks {
            margin-top: 60px;
            padding: 20px;
            background-color: #f8fafc;
            border-radius: 8px;
            border-left: 4px solid #e2e8f0;
        }

        .footer {
            position: fixed;
            bottom: 10px;
            left: 40px;
            right: 40px;
            text-align: center;
            color: #94a3b8;
            font-size: 12px;
            border-top: 1px solid #f1f5f9;
            padding-top: 20px;
        }
    </style>
</head>
<body>
    <div class="header">
        <div class="company-info">
            <h1>IMS</h1>
            <p>Inventory Management System</p>
        </div>
        <div class="report-info">
            <h2>SALES VOUCHER</h2>
            <p>#@Model.Id.ToString("D6")</p>
        </div>
    </div>

    <div class="details-grid">
        <div class="details-col">
            <div class="label">Customer</div>
            <div class="value">@Model.CustomerName</div>
        </div>
        <div class="details-col" style="text-align: right;">
            <div class="label">Date</div>
            <div class="value">@Model.ReportDate.ToString("MMMM dd, yyyy")</div>
        </div>
    </div>

    <table>
        <thead>
            <tr>
                <th>Product Description</th>
                <th class="text-right" style="width: 80px;">Qty</th>
                <th class="text-right" style="width: 150px;">Unit Price</th>
                <th class="text-right" style="width: 150px;">Subtotal</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model.Vouchers)
            {
                <tr>
                    <td style="font-weight: 600;">@item.InventoryName</td>
                    <td class="text-right font-mono">@item.Quantity</td>
                    <td class="text-right font-mono">@item.SellPrice.ToString("N0") MMK</td>
                    <td class="text-right font-mono" style="font-weight: 700;">@item.SubTotal.ToString("N0") MMK</td>
                </tr>
            }
        </tbody>
    </table>

    <div class="totals">
        <div class="total-row grand-total">
            <span>Grand Total</span>
            <span class="font-mono">@Model.TotalAmount.ToString("N0") MMK</span>
        </div>
    </div>

    <div style="clear: both;"></div>

    @if (!string.IsNullOrEmpty(Model.Remarks))
    {
        <div class="remarks">
            <div class="label">Remarks / Notes</div>
            <div style="color: #475569;">@Model.Remarks</div>
        </div>
    }

    <div class="footer">
        Generated by IMS System on @DateTime.Now.ToString("g")
    </div>
</body>
</html>
