@{
    ViewData["Title"] = "Inventory";
}

<div class="sm:flex sm:items-center sm:justify-between mb-8">
    <div>
        <h1 class="text-2xl font-bold text-slate-900 sm:text-3xl tracking-tight">Inventory</h1>
        <p class="mt-2 text-sm text-slate-500">Manage products, prices, and real-time stock levels.</p>
    </div>
    <div class="mt-4 sm:mt-0 sm:ml-16 sm:flex-none">
        <button onclick="showModal()" class="btn-primary gap-2">
            <i data-lucide="plus" class="w-4 h-4"></i>
            Add Product
        </button>
    </div>
</div>

<div class="card">
    <div class="p-4 border-b border-slate-100 bg-slate-50/50 flex flex-col sm:flex-row gap-4 justify-between items-center">
        <div class="flex items-center gap-3 w-full sm:w-auto">
            <div class="relative w-full sm:max-w-xs">
                <div class="absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none text-slate-400">
                    <i data-lucide="search" class="h-4 w-4"></i>
                </div>
                <input type="text" id="search-input" class="input-field pl-10" placeholder="Search products...">
            </div>
            <select id="page-size-select" class="input-field w-24 h-10" onchange="changePageSize(this.value)">
                <option value="10">10</option>
                <option value="25">25</option>
                <option value="50">50</option>
            </select>
        </div>
        <button onclick="loadInventory(1)" class="btn-secondary text-xs h-9 w-full sm:w-auto">
            <i data-lucide="refresh-cw" class="w-4 h-4 mr-2"></i>
            Sync
        </button>
    </div>

    <div class="overflow-x-auto">
        <table class="min-w-full divide-y divide-slate-200">
            <thead class="bg-slate-50">
                <tr>
                    <th class="px-6 py-3.5 text-left text-[11px] font-bold text-slate-500 uppercase tracking-wider">Product</th>
                    <th class="px-6 py-3.5 text-left text-[11px] font-bold text-slate-500 uppercase tracking-wider">Price</th>
                    <th class="px-6 py-3.5 text-left text-[11px] font-bold text-slate-500 uppercase tracking-wider">Stock Level</th>
                    <th class="px-6 py-3.5 text-left text-[11px] font-bold text-slate-500 uppercase tracking-wider">Last Updated</th>
                    <th class="px-6 py-3.5 text-left text-[11px] font-bold text-slate-500 uppercase tracking-wider">Status</th>
                    <th class="relative px-6 py-3.5"><span class="sr-only">Actions</span></th>
                </tr>
            </thead>
            <tbody id="inventory-body" class="bg-white divide-y divide-slate-100">
                <tr>
                    <td colspan="6" class="px-6 py-12 text-center">
                        <div class="flex flex-col items-center justify-center">
                            <i data-lucide="loader-2" class="h-8 w-8 text-indigo-500 animate-spin mb-4"></i>
                            <p class="text-sm text-slate-500 font-medium">Fetching inventory data...</p>
                        </div>
                    </td>
                </tr>
            </tbody>
        </table>
    </div>

    <div id="inventory-pagination"></div>
</div>

<!-- Add/Edit Modal -->
<div id="product-modal" class="fixed inset-0 z-[60] hidden overflow-y-auto" role="dialog" aria-modal="true">
    <div class="flex items-end justify-center min-h-screen pt-4 px-4 pb-20 text-center sm:block sm:p-0">
        <div class="fixed inset-0 bg-slate-900/60" onclick="hideModal()"></div>
        <span class="hidden sm:inline-block sm:align-middle sm:h-screen">&#8203;</span>
        <div class="relative z-10 inline-block align-bottom bg-white rounded-2xl text-left overflow-hidden shadow-2xl sm:my-8 sm:align-middle sm:max-w-lg sm:w-full">
            <div class="bg-white px-4 pt-5 pb-4 sm:p-8 sm:pb-4">
                <div class="sm:flex sm:items-start">
                    <div class="mx-auto flex-shrink-0 flex items-center justify-center h-12 w-12 rounded-xl bg-indigo-50 text-indigo-600 sm:mx-0 sm:h-10 sm:w-10">
                        <i data-lucide="box" class="h-6 w-6"></i>
                    </div>
                    <div class="mt-3 text-center sm:mt-0 sm:ml-4 sm:text-left w-full">
                        <h3 class="text-xl leading-6 font-bold text-slate-900" id="modal-title">New Product</h3>
                        <div class="mt-6 space-y-4">
                            <input type="hidden" id="p-id">
                            <div>
                                <label class="block text-sm font-semibold text-slate-700 mb-1">Product Name</label>
                                <input type="text" id="p-name" class="input-field" placeholder="e.g. Wireless Mouse">
                            </div>
                            <div>
                                <label class="block text-sm font-semibold text-slate-700 mb-1">Unit Price ($)</label>
                                <input type="number" step="0.01" id="p-price" class="input-field" placeholder="0.00">
                            </div>
                        </div>
                    </div>
                </div>
            </div>
            <div class="bg-slate-50 px-4 py-4 sm:px-8 sm:flex sm:flex-row-reverse gap-3">
                <button type="button" onclick="saveProduct()" id="save-btn" class="btn-primary w-full sm:w-auto px-8">Save Product</button>
                <button type="button" onclick="hideModal()" class="btn-secondary w-full sm:w-auto">Cancel</button>
            </div>
        </div>
    </div>
</div>

<!-- Stock Adjust Modal -->
<div id="stock-modal" class="fixed inset-0 z-[60] hidden overflow-y-auto" role="dialog" aria-modal="true">
    <div class="flex items-end justify-center min-h-screen pt-4 px-4 pb-20 text-center sm:block sm:p-0">
        <div class="fixed inset-0 bg-slate-900/60" onclick="hideStockModal()"></div>
        <span class="hidden sm:inline-block sm:align-middle sm:h-screen">&#8203;</span>
        <div class="relative z-10 inline-block align-bottom bg-white rounded-2xl text-left overflow-hidden shadow-2xl sm:my-8 sm:align-middle sm:max-w-sm sm:w-full">
            <div class="p-8">
                <div class="flex items-center gap-4 mb-6">
                    <div class="h-12 w-12 rounded-2xl bg-emerald-50 text-emerald-600 flex items-center justify-center">
                        <i data-lucide="package-check" class="w-6 h-6"></i>
                    </div>
                    <div>
                        <h3 class="text-lg font-bold text-slate-900">Adjust Stock</h3>
                        <p class="text-sm text-slate-400 font-medium" id="stock-product-name"></p>
                    </div>
                </div>
                <input type="hidden" id="stock-inventory-id">
                <div class="space-y-4">
                    <div>
                        <label class="block text-sm font-semibold text-slate-700 mb-1">New Stock Quantity</label>
                        <input type="number" id="stock-amount" class="input-field" placeholder="e.g. 100" min="0">
                        <p class="text-xs text-slate-400 mt-1 font-medium">Enter the total current stock count for this product.</p>
                    </div>
                </div>
            </div>
            <div class="px-8 pb-8 flex flex-row-reverse gap-3">
                <button type="button" onclick="saveStock()" id="stock-save-btn" class="btn-primary px-8">Update Stock</button>
                <button type="button" onclick="hideStockModal()" class="btn-secondary">Cancel</button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
<script>
    document.getElementById('breadcrumb-parent').textContent = 'Workspace';
    document.getElementById('breadcrumb-current').textContent = 'Inventory';

    let currentPage = 1;
    let currentPageSize = 10;

    function stockBadge(stock) {
        if (stock === null || stock === undefined) {
            return `<span class="inline-flex items-center gap-1 px-2.5 py-0.5 rounded-full text-xs font-bold bg-slate-100 text-slate-500 border border-slate-200">
                        <i data-lucide="minus" class="w-3 h-3"></i> N/A
                    </span>`;
        }
        if (stock <= 0) {
            return `<span class="inline-flex items-center gap-1 px-2.5 py-0.5 rounded-full text-xs font-bold bg-rose-50 text-rose-600 border border-rose-100">
                        <i data-lucide="alert-circle" class="w-3 h-3"></i> Out of stock
                    </span>`;
        }
        if (stock <= 10) {
            return `<span class="inline-flex items-center gap-1 px-2.5 py-0.5 rounded-full text-xs font-bold bg-amber-50 text-amber-700 border border-amber-100">
                        <i data-lucide="alert-triangle" class="w-3 h-3"></i> Low (${stock})
                    </span>`;
        }
        return `<span class="inline-flex items-center gap-1 px-2.5 py-0.5 rounded-full text-xs font-bold bg-emerald-50 text-emerald-700 border border-emerald-100">
                    <i data-lucide="check-circle" class="w-3 h-3"></i> ${stock} in stock
                </span>`;
    }

    async function loadInventory(page = 1) {
        currentPage = page;
        const tbody = document.getElementById('inventory-body');
        tbody.innerHTML = `<tr><td colspan="6" class="px-6 py-12 text-center">
            <div class="flex flex-col items-center justify-center">
                <i data-lucide="loader-2" class="h-8 w-8 text-indigo-500 animate-spin mb-4"></i>
                <p class="text-sm text-slate-500 font-medium">Loading...</p>
            </div></td></tr>`;
        lucide.createIcons();

        const result = await window.api.get(`/inventories?pageNumber=${page}&pageSize=${currentPageSize}`);

        if (result && result.isSuccess) {
            const items = result.data || [];
            const paginationMeta = result.pagination || result.Pagination;

            if (items.length === 0) {
                tbody.innerHTML = `<tr><td colspan="6" class="px-6 py-12 text-center text-slate-400 font-medium">No products found.</td></tr>`;
                document.getElementById('inventory-pagination').innerHTML = '';
                return;
            }

            tbody.innerHTML = items.map(item => `
                <tr class="hover:bg-slate-50/80 transition-colors">
                    <td class="px-6 py-4 whitespace-nowrap">
                        <div class="flex items-center">
                            <div class="h-8 w-8 rounded bg-slate-100 flex items-center justify-center mr-3 text-slate-400 flex-shrink-0">
                                <i data-lucide="package" class="w-4 h-4"></i>
                            </div>
                            <span class="text-sm font-bold text-slate-900">${item.name}</span>
                        </div>
                    </td>
                    <td class="px-6 py-4 whitespace-nowrap text-sm font-semibold text-slate-700 tabular-nums">
                        ${new Intl.NumberFormat('en-US', { minimumFractionDigits: 0 }).format(item.price)} MMK
                    </td>
                    <td class="px-6 py-4 whitespace-nowrap">
                        ${stockBadge(item.currentStock)}
                    </td>
                    <td class="px-6 py-4 whitespace-nowrap text-sm text-slate-500 tabular-nums">
                        ${item.lastUpdated
                            ? new Date(item.lastUpdated).toLocaleDateString(undefined, { month: 'short', day: 'numeric', year: 'numeric' })
                            : '<span class="text-slate-300 italic">Never</span>'}
                    </td>
                    <td class="px-6 py-4 whitespace-nowrap">
                        <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-bold
                            ${item.deleteFlag ? 'bg-rose-50 text-rose-600 border border-rose-100' : 'bg-indigo-50 text-indigo-700 border border-indigo-100'}">
                            ${item.deleteFlag ? 'Archived' : 'Active'}
                        </span>
                    </td>
                    <td class="px-6 py-4 whitespace-nowrap text-right text-sm font-medium">
                        <div class="flex justify-end gap-1">
                            <button onclick="showStockModal(${item.id}, '${item.name.replace(/'/g, "\\'")}', ${item.currentStock ?? 0})"
                                title="Adjust stock"
                                class="p-1.5 text-slate-400 hover:text-emerald-600 hover:bg-emerald-50 rounded-lg transition-all">
                                <i data-lucide="package-check" class="w-4 h-4"></i>
                            </button>
                            <button onclick="editProduct(${item.id}, '${item.name.replace(/'/g, "\\'")}', ${item.price})"
                                title="Edit product"
                                class="p-1.5 text-slate-400 hover:text-indigo-600 hover:bg-indigo-50 rounded-lg transition-all">
                                <i data-lucide="edit-3" class="w-4 h-4"></i>
                            </button>
                            <button onclick="deleteProduct(${item.id})"
                                title="Archive"
                                class="p-1.5 text-slate-400 hover:text-rose-600 hover:bg-rose-50 rounded-lg transition-all">
                                <i data-lucide="trash-2" class="w-4 h-4"></i>
                            </button>
                        </div>
                    </td>
                </tr>
            `).join('');
            lucide.createIcons();

            if (paginationMeta) {
                window.pagination.render('inventory-pagination', paginationMeta, loadInventory);
            }
        } else {
            tbody.innerHTML = `<tr><td colspan="6" class="px-6 py-12 text-center text-rose-500 font-bold">
                Failed to load: ${result ? result.message : 'Unknown error'}</td></tr>`;
        }
    }

    function changePageSize(size) {
        currentPageSize = parseInt(size);
        loadInventory(1);
    }

    function showModal() {
        document.getElementById('modal-title').textContent = 'New Product';
        document.getElementById('p-id').value = '';
        document.getElementById('p-name').value = '';
        document.getElementById('p-price').value = '';
        document.getElementById('product-modal').classList.remove('hidden');
    }

    function hideModal() {
        document.getElementById('product-modal').classList.add('hidden');
    }

    function editProduct(id, name, price) {
        document.getElementById('modal-title').textContent = 'Edit Product';
        document.getElementById('p-id').value = id;
        document.getElementById('p-name').value = name;
        document.getElementById('p-price').value = price;
        document.getElementById('product-modal').classList.remove('hidden');
    }

    function showStockModal(id, name, currentStock) {
        document.getElementById('stock-inventory-id').value = id;
        document.getElementById('stock-product-name').textContent = name;
        document.getElementById('stock-amount').value = currentStock;
        document.getElementById('stock-modal').classList.remove('hidden');
    }

    function hideStockModal() {
        document.getElementById('stock-modal').classList.add('hidden');
    }

    async function saveStock() {
        const inventoryId = parseInt(document.getElementById('stock-inventory-id').value);
        const newStock = parseInt(document.getElementById('stock-amount').value);
        const businessId = parseInt(localStorage.getItem('current_business_id'));

        if (isNaN(newStock) || newStock < 0) {
            window.notify.show('Please enter a valid stock quantity', 'error');
            return;
        }

        const btn = document.getElementById('stock-save-btn');
        btn.disabled = true;
        btn.innerHTML = '<i data-lucide="loader-2" class="w-4 h-4 animate-spin mr-2"></i>Saving...';
        lucide.createIcons();

        const result = await window.api.post('/inventories/update-stock', {
            inventoryId,
            businessId,
            currentStock: newStock
        });

        if (result && result.isSuccess) {
            window.notify.show('Stock updated successfully');
            hideStockModal();
            loadInventory(currentPage);
        } else {
            window.notify.show(result.message || 'Stock update failed', 'error');
        }

        btn.disabled = false;
        btn.textContent = 'Update Stock';
    }

    async function saveProduct() {
        const id = document.getElementById('p-id').value;
        const name = document.getElementById('p-name').value;
        const price = parseFloat(document.getElementById('p-price').value);
        const businessId = parseInt(localStorage.getItem('current_business_id'));

        if (!name || isNaN(price)) {
            window.notify.show('Please fill in all required fields', 'error');
            return;
        }

        const saveBtn = document.getElementById('save-btn');
        saveBtn.disabled = true;
        saveBtn.innerHTML = '<i data-lucide="loader-2" class="w-4 h-4 animate-spin mr-2"></i>Saving...';
        lucide.createIcons();

        const result = id
            ? await window.api.put('/inventories', { id: parseInt(id), name, price })
            : await window.api.post('/inventories', { name, price, businessId });

        if (result && result.isSuccess) {
            window.notify.show(`Product ${id ? 'updated' : 'created'} successfully`);
            hideModal();
            loadInventory(currentPage);
        } else {
            window.notify.show(result.message || 'Operation failed', 'error');
        }

        saveBtn.disabled = false;
        saveBtn.textContent = 'Save Product';
    }

    async function deleteProduct(id) {
        if (confirm('Move this product to archives?')) {
            const result = await window.api.delete(`/inventories/${id}`);
            if (result && result.isSuccess) {
                window.notify.show('Product archived');
                loadInventory(currentPage);
            } else {
                window.notify.show(result.message || 'Archive failed', 'error');
            }
        }
    }

    document.getElementById('search-input').addEventListener('input', (e) => {
        const term = e.target.value.toLowerCase();
        document.querySelectorAll('#inventory-body tr').forEach(row => {
            row.style.display = row.innerText.toLowerCase().includes(term) ? '' : 'none';
        });
    });

    loadInventory(1);
</script>
}
